<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Stock Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #0a0a0f;
      --surface: #13131a;
      --surface2: #1c1c28;
      --border: #2a2a3d;
      --accent: #00f5a0;
      --accent2: #00d9f5;
      --danger: #ff4d6d;
      --text: #e8e8f0;
      --muted: #6b6b8a;
      --mono: 'Space Mono', monospace;
      --sans: 'DM Sans', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,245,160,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,245,160,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,15,0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }

    .logo {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--accent);
      letter-spacing: 0.05em;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .logo::before { content: '▲'; font-size: 10px; }

    nav ul { list-style: none; display: flex; gap: 28px; }

    nav a {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    nav a:hover { color: var(--accent); }

    main {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 48px 24px 80px;
    }

    .hero { margin-bottom: 48px; }

    .hero-label {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .hero h1 {
      font-family: var(--mono);
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 700;
      line-height: 1.1;
      background: linear-gradient(135deg, var(--text) 0%, var(--muted) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
    }

    .hero p {
      color: var(--muted);
      font-size: 15px;
      font-weight: 300;
      max-width: 480px;
      line-height: 1.6;
    }

    .search-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 24px 28px;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 36px;
      flex-wrap: wrap;
    }

    .search-panel label {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .ticker-wrap { position: relative; flex: 1; min-width: 160px; }

    .ticker-wrap span {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
      pointer-events: none;
    }

    #stock-ticker {
      width: 100%;
      padding: 12px 14px 12px 32px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text);
      font-family: var(--mono);
      font-size: 15px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    #stock-ticker:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(0,245,160,0.12);
    }

    #stock-ticker::placeholder { color: var(--muted); text-transform: none; }

    .quick-picks { display: flex; gap: 8px; flex-wrap: wrap; }

    .quick-pick {
      font-family: var(--mono);
      font-size: 11px;
      padding: 6px 12px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
      letter-spacing: 0.05em;
    }

    .quick-pick:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(0,245,160,0.06);
    }

    #get-stock {
      padding: 12px 28px;
      background: var(--accent);
      color: #000;
      border: none;
      border-radius: 10px;
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }

    #get-stock:hover {
      background: var(--accent2);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(0,245,160,0.25);
    }

    #get-stock:active { transform: translateY(0); }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 28px;
      opacity: 0;
      transition: opacity 0.4s;
    }

    .stats-row.visible { opacity: 1; }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 20px 22px;
      position: relative;
      overflow: hidden;
    }

    .stat-card::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
    }

    .stat-label {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .stat-value {
      font-family: var(--mono);
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
    }

    .stat-value.up { color: var(--accent); }
    .stat-value.down { color: var(--danger); }
    .stat-sub { font-size: 12px; color: var(--muted); margin-top: 4px; }

    .chart-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
      opacity: 0;
      transition: opacity 0.4s 0.1s;
    }

    .chart-card.visible { opacity: 1; }

    .chart-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .chart-title {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .chart-ticker-label {
      font-family: var(--mono);
      font-size: 24px;
      font-weight: 700;
      color: var(--text);
      margin-top: 2px;
    }

    canvas { max-height: 340px; }

    #status {
      font-family: var(--mono);
      font-size: 12px;
      padding: 10px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      display: none;
    }

    #status.error {
      display: block;
      background: rgba(255,77,109,0.1);
      border: 1px solid rgba(255,77,109,0.3);
      color: var(--danger);
    }

    #status.info {
      display: block;
      background: rgba(0,217,245,0.08);
      border: 1px solid rgba(0,217,245,0.2);
      color: var(--accent2);
    }

    .loader {
      display: none;
      align-items: center;
      gap: 10px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 20px;
    }

    .loader.active { display: flex; }

    .spinner {
      width: 16px; height: 16px;
      border: 2px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    footer {
      text-align: center;
      padding: 28px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      border-top: 1px solid var(--border);
      letter-spacing: 0.05em;
    }

    footer span { color: var(--accent); }
  </style>
</head>
<body>

<header>
  <div class="logo">STOCKPULSE</div>
  <nav>
    <ul>
      <li><a href="#">Dashboard</a></li>
      <li><a href="#">Watchlist</a></li>
      <li><a href="#">Markets</a></li>
    </ul>
  </nav>
</header>

<main>
  <div class="hero">
    <div class="hero-label">// Real-time market data</div>
    <h1>Stock Price<br>Dashboard</h1>
    <p>Fetch daily price data for any ticker. Visualize trends, track key metrics.</p>
  </div>

  <div class="search-panel">
    <label>Ticker</label>
    <div class="ticker-wrap">
      <span>$</span>
      <input type="text" id="stock-ticker" placeholder="AAPL, TSLA, MSFT..." maxlength="10"/>
    </div>
    <div class="quick-picks">
      <button class="quick-pick" data-ticker="AAPL">AAPL</button>
      <button class="quick-pick" data-ticker="TSLA">TSLA</button>
      <button class="quick-pick" data-ticker="MSFT">MSFT</button>
      <button class="quick-pick" data-ticker="NVDA">NVDA</button>
    </div>
    <button id="get-stock">FETCH →</button>
  </div>

  <div id="status"></div>
  <div class="loader" id="loader">
    <div class="spinner"></div>
    <span>Fetching market data...</span>
  </div>

  <div class="stats-row" id="stats-row">
    <div class="stat-card">
      <div class="stat-label">Last Close</div>
      <div class="stat-value" id="stat-price">—</div>
      <div class="stat-sub" id="stat-time">—</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Open</div>
      <div class="stat-value" id="stat-open">—</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">52w High</div>
      <div class="stat-value up" id="stat-high">—</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">52w Low</div>
      <div class="stat-value down" id="stat-low">—</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Volume</div>
      <div class="stat-value" id="stat-vol">—</div>
    </div>
  </div>

  <div class="chart-card" id="chart-card">
    <div class="chart-header">
      <div>
        <div class="chart-title">Daily Closing Price · Last 60 Days</div>
        <div class="chart-ticker-label" id="chart-ticker-label">—</div>
      </div>
    </div>
    <canvas id="stock-chart"></canvas>
  </div>
</main>

<footer>© 2026 <span>STOCKPULSE</span> · Powered by Alpha Vantage</footer>

<script>
  const API_KEY = "56NEDHE27YXU2HPJ";
  let chartInstance = null;

  document.querySelectorAll(".quick-pick").forEach(btn => {
    btn.addEventListener("click", () => {
      document.getElementById("stock-ticker").value = btn.dataset.ticker;
      fetchStock(btn.dataset.ticker);
    });
  });

  document.getElementById("get-stock").addEventListener("click", () => {
    const ticker = document.getElementById("stock-ticker").value.trim().toUpperCase();
    if (!ticker) { showStatus("Please enter a stock ticker symbol.", "error"); return; }
    fetchStock(ticker);
  });

  document.getElementById("stock-ticker").addEventListener("keydown", e => {
    if (e.key === "Enter") document.getElementById("get-stock").click();
  });

  function showStatus(msg, type) {
    const el = document.getElementById("status");
    el.textContent = msg;
    el.className = type;
  }

  function hideStatus() {
    const el = document.getElementById("status");
    el.className = "";
    el.textContent = "";
  }

  function setLoading(on) {
    document.getElementById("loader").classList.toggle("active", on);
    document.getElementById("get-stock").disabled = on;
    document.getElementById("get-stock").textContent = on ? "LOADING..." : "FETCH →";
  }

  function fmt(n) { return parseFloat(n).toFixed(2); }
  function fmtVol(n) {
    n = parseInt(n);
    if (n >= 1e6) return (n / 1e6).toFixed(2) + "M";
    if (n >= 1e3) return (n / 1e3).toFixed(1) + "K";
    return n.toString();
  }

  async function fetchStock(ticker) {
    hideStatus();
    setLoading(true);

    try {
      const url = `https://www.alphavantage.co/query?function=TIME_SERIES_DAILY&symbol=${ticker}&apikey=${API_KEY}`;
      const res = await fetch(url);
      const data = await res.json();

      if (data["Note"]) {
        showStatus("⚠ API rate limit reached. Please wait a minute and try again.", "error");
        setLoading(false);
        return;
      }

      if (data["Information"]) {
        showStatus("⚠ API limit reached for today. Try again tomorrow or use a new key.", "error");
        setLoading(false);
        return;
      }

      if (data["Error Message"] || !data["Time Series (Daily)"]) {
        showStatus("Invalid ticker symbol. Please try again.", "error");
        setLoading(false);
        return;
      }

      const series = data["Time Series (Daily)"];
      const dates = Object.keys(series).slice(0, 60).reverse();
      const prices = dates.map(d => parseFloat(series[d]["4. close"]));
      const highs  = dates.map(d => parseFloat(series[d]["2. high"]));
      const lows   = dates.map(d => parseFloat(series[d]["3. low"]));
      const vols   = dates.map(d => parseInt(series[d]["5. volume"]));

      const latest = series[Object.keys(series)[0]];
      const latestDate = Object.keys(series)[0];

      document.getElementById("stat-price").textContent = "$" + fmt(latest["4. close"]);
      document.getElementById("stat-time").textContent = latestDate;
      document.getElementById("stat-open").textContent = "$" + fmt(latest["1. open"]);
      document.getElementById("stat-high").textContent = "$" + fmt(Math.max(...highs));
      document.getElementById("stat-low").textContent  = "$" + fmt(Math.min(...lows));
      document.getElementById("stat-vol").textContent  = fmtVol(parseInt(latest["5. volume"]));
      document.getElementById("chart-ticker-label").textContent = ticker;

      document.getElementById("stats-row").classList.add("visible");
      document.getElementById("chart-card").classList.add("visible");

      renderChart(dates, prices, ticker);

    } catch (err) {
      showStatus("Network error — check your connection and try again.", "error");
    }

    setLoading(false);
  }

  function renderChart(labels, prices, ticker) {
    const ctx = document.getElementById("stock-chart").getContext("2d");
    if (chartInstance) chartInstance.destroy();

    const isUp = prices[prices.length - 1] >= prices[0];
    const color = isUp ? "#00f5a0" : "#ff4d6d";
    const colorStart = isUp ? "rgba(0,245,160,0.18)" : "rgba(255,77,109,0.18)";

    const gradient = ctx.createLinearGradient(0, 0, 0, 320);
    gradient.addColorStop(0, colorStart);
    gradient.addColorStop(1, "rgba(0,0,0,0)");

    chartInstance = new Chart(ctx, {
      type: "line",
      data: {
        labels,
        datasets: [{
          label: ticker,
          data: prices,
          borderColor: color,
          borderWidth: 2,
          pointRadius: 0,
          pointHoverRadius: 4,
          pointHoverBackgroundColor: color,
          fill: true,
          backgroundColor: gradient,
          tension: 0.35
        }]
      },
      options: {
        responsive: true,
        interaction: { intersect: false, mode: "index" },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: "#13131a",
            borderColor: "#2a2a3d",
            borderWidth: 1,
            titleColor: "#6b6b8a",
            bodyColor: "#e8e8f0",
            titleFont: { family: "Space Mono", size: 11 },
            bodyFont: { family: "Space Mono", size: 13 },
            callbacks: {
              label: ctx => " $" + ctx.parsed.y.toFixed(2)
            }
          }
        },
        scales: {
          x: {
            grid: { color: "rgba(255,255,255,0.03)" },
            ticks: {
              color: "#6b6b8a",
              font: { family: "Space Mono", size: 10 },
              maxTicksLimit: 10,
              maxRotation: 0
            },
            border: { color: "#2a2a3d" }
          },
          y: {
            position: "right",
            grid: { color: "rgba(255,255,255,0.04)" },
            ticks: {
              color: "#6b6b8a",
              font: { family: "Space Mono", size: 10 },
              callback: v => "$" + v.toFixed(2)
            },
            border: { color: "#2a2a3d" }
          }
        }
      }
    });
  }
</script>
</body>
</html>